# TechNovance HR Chatbot backend environment variables
AI_PROVIDER=google_genai
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GROQ_API_KEY=YOUR_GROQ_API_KEY
GROQ_MODEL_NAME=llama-3.1-8b-instant
GROQ_API_URL=YOUR_GROQ_API_URL
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
COMPANY_NAME=TechNovance Solutions
HR_EMAIL=hr@technovance.com
HR_PHONE=+91-7416279128
HRMS_PORTAL=https://hrms.technovance.internal


MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-host>/<database>?retryWrites=true&w=majority
JWT_SECRET=replace-with-a-secure-random-secret
JWT_EXP_MINUTES=1440
# Vector Database (Pinecone) - NEW!
# Sign up at https://www.pinecone.io and get your API key
PINECONE_API_KEY=YOUR_PINECONE_API_KEY
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=hrbot-policies-employees
PINECONE_DIMENSION=384

# Embeddings Model (Sentence Transformers)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Additional Configuration
ENVIRONMENT=development
DEBUG=False
LOG_LEVEL=INFO
